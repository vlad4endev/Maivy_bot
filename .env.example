# --- Подключение к Convex (единственные переменные на сервере) ---

# URL деплоя Convex (из npx convex dev или Dashboard)
CONVEX_URL=

# Секрет API (задаётся в Convex Dashboard → Environment Variables)
BOT_API_SECRET=

# Slug бота из админ-панели (должен совпадать с slug в разделе «Боты»)
BOT_SLUG=maivy

# --- Все остальные настройки бота — в админ-панели → Настройки ---
# TELEGRAM_BOT_TOKEN, MAX_BOT_TOKEN, ENABLED_PLATFORMS,
# BOT_TAGLINE, PRIVACY_POLICY_URL, LOOM_VIDEO_URL, GROSTER_URL,
# CONTACT_USERNAME, WELCOME_IMAGE_PATH, WELCOME_VIDEO_PATH и др.
