# Self-hosted Docker stack (без npx convex login)
# cp .env.example .env && ./scripts/setup-self-hosted.sh

# --- Публичные URL (браузер и админка) ---
# Замените YOUR_SERVER_IP на IP или домен вашего сервера
PUBLIC_CONVEX_URL=http://YOUR_SERVER_IP:3210
PUBLIC_CONVEX_SITE_URL=http://YOUR_SERVER_IP:3211

# --- Порты на хосте ---
CONVEX_HTTP_PORT=3210
CONVEX_SITE_PORT=3211
ADMIN_PORT=8080

# --- Секреты (сгенерируйте: openssl rand -hex 32) ---
POSTGRES_PASSWORD=
INSTANCE_SECRET=
CONVEX_ADMIN_KEY=
ADMIN_PASSWORD=
BOT_API_SECRET=

# --- Бот (процесс npm run dev / Docker-контейнер bot) ---
CONVEX_URL=http://127.0.0.1:3210
BOT_API_SECRET=
BOT_SLUG=maivy

# --- MAX (production: webhook обязателен, см. dev.max.ru/docs) ---
# MAX_WEBHOOK_URL=https://your-domain.com/max/webhook
# MAX_WEBHOOK_SECRET=random_secret_5_chars_min
# MAX_WEBHOOK_PORT=3000
# MAX_WEBHOOK_PATH=/max/webhook
