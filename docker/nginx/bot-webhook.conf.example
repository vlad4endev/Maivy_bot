# Reverse proxy для webhook бота (Telegram + MAX).
# Скопируйте на сервер, например:
#   /etc/nginx/sites-available/bot.maivy.ru
#   ln -s .../bot.maivy.ru /etc/nginx/sites-enabled/
#   nginx -t && systemctl reload nginx
#
# WEBHOOK_PORT в .env / docker-compose.override.yml — обычно 3001.
#
# nginx на ХОСТЕ (systemd): proxy_pass http://127.0.0.1:3001;
#
# nginx в DOCKER (контейнер nginx-proxy и т.п.):
#   127.0.0.1 внутри контейнера — НЕ хост! curl с хоста на :3001 работает,
#   а https://bot.maivy.ru даёт 502, пока upstream неверный.
#
# Вариант A — gateway хоста (чаще всего):
#   proxy_pass http://172.17.0.1:3001;
#
# Вариант B — та же docker-сеть, что и maivy-bot:
#   docker network connect app_default nginx-proxy
#   proxy_pass http://maivy-bot:3001;
#
# Вариант C — host.docker.internal (добавьте в nginx-proxy):
#   extra_hosts: ["host.docker.internal:host-gateway"]
#   proxy_pass http://host.docker.internal:3001;
#
# Найти конфиг: docker exec nginx-proxy grep -r bot.maivy /etc/nginx/

server {
    listen 80;
    server_name bot.maivy.ru;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name bot.maivy.ru;

    # certbot --nginx -d bot.maivy.ru
    ssl_certificate     /etc/letsencrypt/live/bot.maivy.ru/fullchain.pem;
    ssl_certificate_key   /etc/letsencrypt/live/bot.maivy.ru/privkey.pem;

    location /telegram/webhook {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Обязательно, если задан TELEGRAM_WEBHOOK_SECRET:
        proxy_set_header X-Telegram-Bot-Api-Secret-Token $http_x_telegram_bot_api_secret_token;
    }

    location /max/webhook {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Обязательно, если задан MAX_WEBHOOK_SECRET:
        proxy_set_header X-Max-Bot-Api-Secret $http_x_max_bot_api_secret;
    }
}
